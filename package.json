    "otpauth": "^9.5.1",
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@prisma/client": "^5.22.0",
    "@types/node": "^25.9.2",
    "@types/qrcode": "^1.5.6",
    "dotenv": "^17.4.2",
    "prisma": "^5.22.0",
    "typescript": "^6.0.3"
  }
