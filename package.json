{
  "name": "nexo-digital",
  "type": "module",
  "version": "1.0.0",
  "description": "Comunidad para creadores del mundo digital — portal de empleos, recursos, proyectos y eventos con moderación y autenticación.",
  "keywords": [
    "astro",
    "supabase",
    "prisma",
    "comunidad",
    "empleos",
    "recursos",
    "proyectos",
    "eventos",
    "moderacion",
    "2fa",
    "totp"
  ],
  "homepage": "https://github.com/Shinigamy19/Nexo-Digital#readme",
  "bugs": {
    "url": "https://github.com/Shinigamy19/Nexo-Digital/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Shinigamy19/Nexo-Digital.git"
  },
  "license": "MIT",
  "author": "Nexo Digital Community",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "start": "node --env-file-if-exists=.env dist/server/entry.mjs",
    "start:prod": "npm run build && npm run start",
    "preview": "astro preview",
    "typecheck": "astro check",
    "smoke": "node scripts/smoke-test.mjs",
    "e2e": "node --env-file-if-exists=.env scripts/e2e-test.mjs",
    "db:check": "node scripts/db-check.mjs",
    "db:migrate": "node scripts/db-migrate.mjs",
    "astro": "astro"
  },
  "dependencies": {
    "@astrojs/node": "^10.1.3",
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.107.0",
