# ──────────────────────────────────────────────────────────────────────
# Nexo Digital — Variables de entorno
# ──────────────────────────────────────────────────────────────────────
# Copiá este archivo como .env y completá los valores.
# NUNCA commitees el archivo .env — está en .gitignore.
#
# PUBLIC_* se expone al navegador (bundle del cliente).
# Las demás son server-only y NUNCA deben aparecer en el frontend.
# ──────────────────────────────────────────────────────────────────────

# URL pública del sitio (sin trailing slash). Usada para OAuth redirects
# y links de confirmación de email.
PUBLIC_SITE_URL=http://localhost:4321

# ─── Supabase ────────────────────────────────────────────────────────
# Crear proyecto en https://supabase.com/dashboard → Project Settings → API

# Project URL (Settings → API → Project URL)
PUBLIC_SUPABASE_URL=https://TU-PROJECT-ID.supabase.co

# Anon / Publishable key (Settings → API → publishable key)
# Seguro para el navegador (RLS protege el acceso).
PUBLIC_SUPABASE_ANON_KEY=sb_publishable_TU_ANON_KEY

# Service role key (Settings → API → secret key)
# ⚠️ SOLO server-side. Nunca exponer al navegador.
SUPABASE_SERVICE_ROLE_KEY=sb_secret_TU_SERVICE_ROLE_KEY

# ─── Base de datos (Prisma) ──────────────────────────────────────────
# Connection string directa a PostgreSQL.
# Formato: postgresql://postgres:SUA_PASSWORD@HOST:5432/postgres
DATABASE_URL=postgresql://postgres:TU_PASSWORD@db.TU-PROJECT-ID.supabase.co:5432/postgres
DIRECT_URL=postgresql://postgres:TU_PASSWORD@db.TU-PROJECT-ID.supabase.co:5432/postgres
