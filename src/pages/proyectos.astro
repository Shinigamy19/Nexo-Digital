---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/layout/Navbar.astro';
import Footer from '../components/layout/Footer.astro';
import ProjectCard from '../components/projects/ProjectCard.astro';
import FilterBar from '../components/ui/FilterBar.astro';
import logoImg from '../assets/logo.webp';
import projectsData from '../data/projects.json';

const GITHUB_REPO = "https://github.com/Shinigamy19/Nexo-Digital";
const NEW_PROJECT_URL = `${GITHUB_REPO}/issues/new?template=nuevo_proyecto.md&title=%5BPROYECTO%5D+Nombre+de+tu+proyecto&labels=proyecto,pendiente-revision`;

const filterOptions = [
  { value: 'desarrollo', label: '💻 Desarrollo' },
  { value: 'diseño',     label: '🎨 Diseño' },
  { value: 'ia',         label: '🤖 IA' },
  { value: 'iot',        label: '🏠 IoT' },
  { value: 'edicion',    label: '🎬 Edición' },
  { value: 'audio',      label: '🎧 Audio' },
  { value: 'gamedev',    label: '🕹️ Game Dev' },
];
---

<Layout
  title="Proyectos — Nexo Digital"
  description="Biblioteca de proyectos open source impulsados por la comunidad de Nexo Digital. Desarrolladores, diseñadores, creadores y makers compartiendo sus creaciones."
>
  <Navbar />

  <main>
    <section class="projects-hero">
      <div class="container">
        <div class="section-badge reveal">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
          Open Source
        </div>
        <h1 class="section-title reveal reveal-delay-1">
          Proyectos de la<br/><span class="gradient-text">comunidad</span>
        </h1>
        <p class="section-subtitle reveal reveal-delay-2">
          Proyectos reales construidos por miembros de Nexo Digital. Explorá, contribuí y mostrá lo que vos también estás construyendo.
        </p>

        <div class="hero-actions reveal reveal-delay-3">
          <a href={NEW_PROJECT_URL} class="btn-submit" target="_blank" rel="noopener noreferrer" id="projects-submit-btn">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
            Agregar mi proyecto
          </a>
          <span class="moderation-note">
            <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            Revisado por moderadores antes de publicarse
          </span>
        </div>
      </div>
    </section>

    <section class="projects-list">
      <div class="container">
        <div class="list-header reveal">
          <div class="results-info">
            <span class="results-count">{projectsData.length} proyecto{projectsData.length !== 1 ? 's' : ''}</span>
          </div>
          <FilterBar id="projects" options={filterOptions} />
        </div>

        <div class="projects-grid">
          {projectsData.map((project, i) => (
            <div
              data-category={project.category}
              data-filtergroup="projects"
              class={`reveal reveal-delay-${(i % 3) + 1}`}
            >
              <ProjectCard {...project} />
            </div>
          ))}
        </div>

        <div class="contribute-cta reveal">
          <div class="cta-inner">
            <span class="cta-icon" aria-hidden="true">🚀</span>
            <div class="cta-text">
              <strong>¿Tenés un proyecto para mostrar?</strong>
              <p>Abrí un Issue en GitHub con los datos de tu proyecto y un moderador lo revisará en 24–48hs.</p>
            </div>
            <a href={NEW_PROJECT_URL} class="cta-link" target="_blank" rel="noopener noreferrer">
              Proponer proyecto
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </a>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer logoImg={logoImg} />
</Layout>

<script>
  const revealEls = document.querySelectorAll('.reveal');
  const observer = new IntersectionObserver(
    entries => entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); }),
    { threshold: 0.1 }
  );
  revealEls.forEach(el => observer.observe(el));
</script>

<style>
  .projects-hero {
    padding-top: 10rem;
    padding-bottom: 3rem;
    text-align: center;
  }
  .projects-hero .section-badge {
    margin-bottom: 1.5rem;
  }
  .projects-hero .section-subtitle {
    margin: 0 auto 2rem;
  }

  .hero-actions {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
  }
  .btn-submit {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.7rem 1.6rem;
    border-radius: 12px;
    background: var(--gradient-main);
    color: #fff;
    font-weight: 700;
    font-size: 0.95rem;
    text-decoration: none;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
    box-shadow: 0 4px 20px rgba(168, 85, 247, 0.35);
  }
  .btn-submit:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 32px rgba(168, 85, 247, 0.55);
  }
  .moderation-note {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.78rem;
    color: var(--text-muted);
  }

  .projects-list { padding-top: 1rem; }

  .list-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1rem;
    margin-bottom: 2.5rem;
  }
  .results-count {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--text-muted);
  }

  .projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1.5rem;
  }

  .contribute-cta {
    margin-top: 4rem;
    margin-bottom: 2rem;
  }
  .cta-inner {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    background: var(--bg-card);
    border: 1px solid rgba(168, 85, 247, 0.2);
    border-radius: 16px;
    padding: 1.5rem 2rem;
    flex-wrap: wrap;
  }
  .cta-icon { font-size: 2rem; flex-shrink: 0; }
  .cta-text {
    flex: 1;
    min-width: 200px;
  }
  .cta-text strong {
    display: block;
    color: var(--text-primary);
    font-size: 1rem;
    margin-bottom: 0.3rem;
  }
  .cta-text p { font-size: 0.85rem; color: var(--text-secondary); line-height: 1.6; }
  .cta-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-weight: 700;
    font-size: 0.88rem;
    color: var(--purple);
    text-decoration: none;
    padding: 0.55rem 1.2rem;
    border: 1px solid rgba(168, 85, 247, 0.35);
    border-radius: 10px;
    background: rgba(168, 85, 247, 0.08);
    transition: all 0.2s ease;
    white-space: nowrap;
  }
  .cta-link:hover {
    background: rgba(168, 85, 247, 0.18);
    border-color: rgba(168, 85, 247, 0.6);
    color: var(--text-primary);
  }

  @media (max-width: 768px) {
    .list-header { flex-direction: column; align-items: flex-start; }
    .cta-inner { flex-direction: column; align-items: flex-start; }
  }
</style>
