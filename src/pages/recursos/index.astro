---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/layout/Navbar/index.astro';
import Footer from '../../components/layout/Footer/index.astro';
import ResourceCard from '../../components/resources/ResourceCard/index.astro';
import FilterBar from '../../components/ui/FilterBar/index.astro';
import logoImg from '../../assets/brand/logo.webp';
import resourcesData from '../../data/resources.json';
import styles from './recursos.module.css';

const GITHUB_REPO = "https://github.com/NexoDigital-Lab/Nexo-Digital";
const NEW_RESOURCE_URL = `${GITHUB_REPO}/issues/new?template=nuevo_recurso.md&title=%5BRECURSO%5D+Nombre+del+recurso&labels=recurso,pendiente-revision`;

const typeOptions = [
  { value: 'herramienta',   label: '🔧 Herramienta' },
  { value: 'tutorial',      label: '📖 Tutorial' },
  { value: 'recurso',       label: '🔗 Recurso' },
  { value: 'template',      label: '📄 Template' },
  { value: 'documentación', label: '📚 Docs' },
];
---

<Layout
  title="Recursos — Nexo Digital"
  description="Biblioteca de recursos curada por la comunidad de Nexo Digital: herramientas, tutoriales, templates, repositorios y documentación para el mundo digital."
>
  <Navbar />

  <main>
    <section class={styles['resources-hero']}>
      <div class="container">
        <div class="section-badge reveal">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
          Recursos
        </div>
        <h1 class="section-title reveal reveal-delay-1">
          Biblioteca de<br/><span class="gradient-text">recursos</span>
        </h1>
        <p class="section-subtitle reveal reveal-delay-2">
          Herramientas, tutoriales, templates y recursos seleccionados y recomendados por la comunidad. Todo en un solo lugar.
        </p>

        <div class={`${styles['hero-actions']} reveal reveal-delay-3`}>
          <a href={NEW_RESOURCE_URL} class={styles['btn-submit']} target="_blank" rel="noopener noreferrer" id="resources-submit-btn">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
            Sugerir un recurso
          </a>
          <span class={styles['moderation-note']}>
            <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            Revisado por moderadores antes de publicarse
          </span>
        </div>
      </div>
    </section>

    <section class={styles['resources-list']}>
      <div class="container">
        <div class={`${styles['list-header']} reveal`}>
          <div>
            <span class={styles['results-count']}>{resourcesData.length} recurso{resourcesData.length !== 1 ? 's' : ''}</span>
          </div>
          <FilterBar id="resources" options={typeOptions} allLabel="Todos los tipos" />
        </div>

        <div class={styles['resources-grid']}>
          {resourcesData.map((resource, i) => (
            <div
              data-category={resource.type}
              data-filtergroup="resources"
              class={`reveal reveal-delay-${(i % 3) + 1}`}
            >
              <ResourceCard {...resource} />
            </div>
          ))}
        </div>

        <div class={`${styles['contribute-cta']} reveal`}>
          <div class={styles['cta-inner']}>
            <span class={styles['cta-icon']} aria-hidden="true">📚</span>
            <div class={styles['cta-text']}>
              <strong>¿Conocés un recurso que debería estar acá?</strong>
              <p>Abrí un Issue en GitHub con el link y descripción. Los moderadores lo revisarán y agregarán si cumple los criterios de calidad.</p>
            </div>
            <a href={NEW_RESOURCE_URL} class={styles['cta-link']} target="_blank" rel="noopener noreferrer">
              Sugerir recurso
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </a>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer logoImg={logoImg} />
</Layout>

<script>
  const revealEls = document.querySelectorAll('.reveal');
  const observer = new IntersectionObserver(
    entries => entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); }),
    { threshold: 0.1 }
  );
  revealEls.forEach(el => observer.observe(el));
</script>


