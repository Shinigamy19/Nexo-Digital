---
export const prerender = false;

import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/layout/Navbar/index.astro';
import Footer from '../../components/layout/Footer/index.astro';
import logoImg from '../../assets/brand/logo.webp';
import { isAuthenticated } from '../../lib/roles';
import { submissionErrorMessage } from '../../lib/submission-errors';
import { RESOURCE_CATEGORIES, RESOURCE_TYPES } from '../../lib/portal-meta';
import styles from '../../styles/forms.module.css';

const user = Astro.locals.user;
if (!isAuthenticated(user)) {
  return Astro.redirect('/login?next=' + encodeURIComponent('/recursos/nuevo'), 303);
}

const errorCode = Astro.url.searchParams.get('error');
const fieldName = Astro.url.searchParams.get('field');
const errorMessage = submissionErrorMessage(errorCode);
const createdId = Astro.url.searchParams.get('id');
const justCreated = Astro.url.searchParams.get('created') === 'resource';
---

<Layout
  title="Recomendar recurso — Nexo Digital"
  description="Compartí una herramienta, tutorial o recurso útil con la comunidad Nexo Digital."
>
  <Navbar />
  <main class={styles.page}>
    <div class={styles.card}>
      <header class={styles.header}>
        <h1 class={styles.title}>Recomendar un recurso</h1>
        <p class={styles.subtitle}>
          Tu recomendación queda en revisión. La aprueba un moderador antes de salir al público.
        </p>
      </header>

      {errorMessage && (
        <p class={styles.error} role="alert">
          ⚠️ {errorMessage}
          {fieldName && <small> (campo: <code>{fieldName}</code>)</small>}
        </p>
      )}

      {justCreated && createdId && (
        <p class={styles.disclaimer}>
          ✅ Recurso enviado (id <code>{createdId.slice(0, 8)}</code>). Te avisamos cuando se apruebe.
        </p>
      )}

      <form method="POST" action="/api/recursos" class={styles.form} novalidate>
        <div class={styles.field}>
          <label class={styles.label} for="title">Nombre del recurso <span class={styles.required}>*</span></label>
          <input class={styles.input} type="text" id="title" name="title" required minlength="4" maxlength="120" placeholder="Figma — Editor de diseño" />
        </div>

        <div class={styles.field}>
          <label class={styles.label} for="description">Descripción <span class={styles.required}>*</span></label>
          <textarea class={styles.textarea} id="description" name="description" required minlength="20" maxlength="2000" placeholder="¿Qué es? ¿Por qué lo recomendás? ¿Para quién es útil?"></textarea>
        </div>

        <div class={styles.row}>
          <div class={styles.field}>
            <label class={styles.label} for="type">Tipo <span class={styles.required}>*</span></label>
            <select class={styles.select} id="type" name="type" required>
              <option value="" disabled selected>Elegí…</option>
              {RESOURCE_TYPES.map((t) => (
                <option value={t.value}>{t.emoji} {t.label}</option>
              ))}
            </select>
          </div>

          <div class={styles.field}>
            <label class={styles.label} for="category">Categoría <span class={styles.required}>*</span></label>
            <select class={styles.select} id="category" name="category" required>
              <option value="" disabled selected>Elegí…</option>
              {RESOURCE_CATEGORIES.map((c) => (
                <option value={c.value}>{c.emoji} {c.label}</option>
              ))}
            </select>
          </div>
        </div>

        <div class={styles.field}>
          <label class={styles.label} for="url">Link <span class={styles.required}>*</span></label>
          <input class={styles.input} type="url" id="url" name="url" required minlength="8" maxlength="500" placeholder="https://figma.com" />
          <span class={styles.hint}>URL completa, con https://.</span>
        </div>

        <div class={styles.field}>
          <label class={styles.label} for="tags">Tags</label>
          <input class={styles.input} type="text" id="tags" name="tags" placeholder="diseño, ui, gratis" />
          <span class={styles.hint}>Opcional. Separalas con comas.</span>
        </div>

        <div class={styles.field}>
          <label class={styles.label} for="added_by">Tu nombre o el de quien recomienda <span class={styles.required}>*</span></label>
          <input class={styles.input} type="text" id="added_by" name="added_by" required minlength="1" maxlength="80" placeholder="Ana Pérez" />
        </div>

        <div class={styles.actions}>
          <button type="submit" class={styles.submit}>Enviar a revisión</button>
          <a href="/recursos" class={styles.cancel}>Cancelar</a>
        </div>
      </form>
    </div>
  </main>
  <Footer />
</Layout>

<script>
  const form = document.querySelector('form');
  if (!form) throw new Error('Form not found');
  const key = 'form-draft:' + (form.getAttribute('action') || 'unknown');
  const hasError = new URLSearchParams(location.search).has('error');

  if (hasError) {
    const saved = sessionStorage.getItem(key);
    if (saved) {
      const data: Record<string, string> = JSON.parse(saved);
      for (const [name, value] of Object.entries(data)) {
        const el = form.elements.namedItem(name);
        if (!el) continue;
        if (el instanceof RadioNodeList) {
          for (const radio of el) {
            if (radio instanceof HTMLInputElement) radio.checked = radio.value === value;
          }
        } else if (el instanceof HTMLInputElement && el.type === 'checkbox') {
          (el as HTMLInputElement).checked = value === 'true';
        } else if (el instanceof HTMLSelectElement || el instanceof HTMLInputElement || el instanceof HTMLTextAreaElement) {
          el.value = value;
        }
      }
      sessionStorage.removeItem(key);
    }
  } else {
    sessionStorage.removeItem(key);
  }

  form.addEventListener('submit', () => {
    const fd = new FormData(form);
    const data: Record<string, string> = {};
    for (const [key, val] of fd.entries()) {
      if (typeof val === 'string') data[key] = val;
    }
    sessionStorage.setItem(key, JSON.stringify(data));
  });
</script>
