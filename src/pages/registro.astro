---
export const prerender = false;

import Layout from '../layouts/Layout.astro';
import AuthCard from '../components/auth/AuthCard.astro';
import OAuthButtons from '../components/auth/OAuthButtons.astro';
import styles from '../components/auth/AuthCard.module.css';

const url = Astro.url;
const next = url.searchParams.get('next') ?? '/perfil';
const error = url.searchParams.get('error');

const errorMessages: Record<string, string> = {
  signup_disabled: 'El registro está deshabilitado temporalmente.',
  email_taken: 'Ya existe una cuenta con ese email.',
  weak_password: 'La contraseña debe tener al menos 8 caracteres.',
  invalid_email: 'El email no es válido.',
  invalid_username: 'El usuario debe tener entre 3 y 30 caracteres. Solo letras, números y guiones bajos.',
  username_taken: 'Ese nombre de usuario ya está en uso. Probá con otro.',
  passwords_mismatch: 'Las contraseñas no coinciden.',
  generic: 'No pudimos crear la cuenta. Probá de nuevo.',
};

const errorMessage = error ? (errorMessages[error] ?? errorMessages.generic) : null;
---

<Layout title="Crear cuenta — Nexo Digital">
  <main style="min-height: 100dvh; display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 6rem 1.5rem 2rem;">
    <a href="/" style="position: fixed; top: 1.5rem; left: 1.5rem; display: flex; align-items: center; gap: 0.4rem; text-decoration: none; color: var(--text); font-weight: 500; font-size: 0.9rem; opacity: 0.7; transition: opacity 0.2s;" onmouseover="this.style.opacity='1'" onmouseout="this.style.opacity='0.7'">
      ← Inicio
    </a>
    <a href="/" style="display: flex; align-items: center; gap: 0.5rem; text-decoration: none; color: var(--text); margin-bottom: 2rem; font-weight: 600;">
      <img src="/favicons/logo.webp" alt="Nexo Digital" width="32" height="32" style="border-radius: 8px;" />
      Nexo <span class="gradient-text">Digital</span>
    </a>
    <AuthCard
      title="Unite a Nexo Digital"
      subtitle="Creá tu cuenta para guardar tu perfil, guardar proyectos y participar."
      error={errorMessage}
    >
      <OAuthButtons next={next} />
      <p style="text-align:center;font-size:0.78rem;color:var(--text-muted);margin-top:-0.5rem;margin-bottom:0;">Podés vincular o desvincular cuentas después desde <a href="/perfil/editar?tab=seguridad" style="color:var(--cyan);text-decoration:none;">Seguridad</a></p>

      <div class={styles.divider}>o con email</div>

      <form class={styles.form} method="POST" action={`/api/auth/signup?next=${encodeURIComponent(next)}`}>
        <div class={styles.field}>
          <label class={styles.label} for="username">Nombre de usuario</label>
          <input
            class={styles.input}
            type="text"
            id="username"
            name="username"
            required
            autocomplete="username"
            minlength="3"
            maxlength="30"
            pattern="^[a-zA-Z0-9_]+$"
            placeholder="TuUsuario"
          />
          <p class={styles.hint}>Entre 3 y 30 caracteres. Solo letras, números y guiones bajos.</p>
        </div>

        <div class={styles.field}>
          <label class={styles.label} for="email">Email</label>
          <input
            class={styles.input}
            type="email"
            id="email"
            name="email"
            required
            autocomplete="email"
            placeholder="tu@email.com"
          />
        </div>

        <div class={styles.field}>
          <label class={styles.label} for="password">Contraseña</label>
          <div class={styles.passwordWrapper}>
            <input
              class={styles.input}
              type="password"
              id="password"
              name="password"
              required
              autocomplete="new-password"
              minlength="8"
              placeholder="Mínimo 8 caracteres"
            />
            <button class={styles.togglePassword} type="button" aria-label="Mostrar contraseña" data-toggle="password">👁</button>
          </div>
          <p class={styles.hint}>Al menos 8 caracteres. Mezclá letras, números y símbolos si podés.</p>
        </div>

        <div class={styles.field}>
          <label class={styles.label} for="password_confirm">Confirmar contraseña</label>
          <div class={styles.passwordWrapper}>
            <input
              class={styles.input}
              type="password"
              id="password_confirm"
              name="password_confirm"
              required
              autocomplete="new-password"
              minlength="8"
              placeholder="Repetí la contraseña"
            />
            <button class={styles.togglePassword} type="button" aria-label="Mostrar contraseña" data-toggle="password">👁</button>
          </div>
        </div>

        <div class={styles.checkboxRow}>
          <input type="checkbox" id="terms" name="terms" value="true" required />
          <label for="terms">Acepto los términos y la política de privacidad</label>
        </div>

        <button class={styles.submit} type="submit">Crear cuenta</button>
      </form>

<script>
  document.querySelectorAll<HTMLButtonElement>('[data-toggle="password"]').forEach(btn => {
    btn.addEventListener('click', () => {
      const input = (btn.parentElement?.querySelector('.input') ?? btn.previousElementSibling) as HTMLInputElement | null;
      if (!input) return;
      const isPassword = input.type === 'password';
      input.type = isPassword ? 'text' : 'password';
      btn.textContent = isPassword ? '\u{1F648}' : '\u{1F441}';
      btn.setAttribute('aria-label', isPassword ? 'Ocultar contraseña' : 'Mostrar contraseña');
    });
  });
</script>

      <div class={styles.footer}>
        ¿Ya tenés cuenta? <a href={`/login?next=${encodeURIComponent(next)}`}>Iniciar sesión</a>
      </div>
    </AuthCard>
  </main>
</Layout>
