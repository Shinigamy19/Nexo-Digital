---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/layout/Navbar.astro';
import Hero from '../components/home/Hero.astro';
import Presentation from '../components/home/Presentation.astro';
import Objectives from '../components/home/Objectives.astro';
import ChannelsSection from '../components/home/ChannelsSection.astro';
import Philosophy from '../components/home/Philosophy.astro';
import Invite from '../components/home/Invite.astro';
import Footer from '../components/layout/Footer.astro';

import logoImg from '../assets/logo.webp';
import qrLightImg from '../assets/qr-light.webp';
import communityData from '../data/community.json';

const WHATSAPP_LINK = "https://chat.whatsapp.com/Hbm9wubODmw2ycWx5DTcMZ";
---

<Layout>
  <Navbar />

  <main>
    <Hero whatsappLink={WHATSAPP_LINK} />
    
    <Presentation 
      logoImg={logoImg} 
      areas={communityData.areas} 
    />

    <Objectives />

    <ChannelsSection channels={communityData.channels} />

    <Philosophy />

    <Invite 
      whatsappLink={WHATSAPP_LINK} 
      qrLightImg={qrLightImg} 
    />
  </main>

  <Footer logoImg={logoImg} />
</Layout>

<script>
  // ---- Intersection Observer para reveal animations ----
  const revealEls = document.querySelectorAll('.reveal');
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
        }
      });
    },
    { threshold: 0.12 }
  );
  revealEls.forEach(el => observer.observe(el));
</script>
