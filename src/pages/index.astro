---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';

const WHATSAPP_LINK = "https://chat.whatsapp.com/nexodigital"; // Reemplazar con link real
---

<Layout>
  <Navbar />

  <!-- ===================== HERO ===================== -->
  <section id="inicio" class="hero">
    <!-- Fondo animado de partículas/red -->
    <canvas id="heroCanvas" class="hero-canvas" aria-hidden="true"></canvas>

    <!-- Halo de brillo central -->
    <div class="hero-glow" aria-hidden="true"></div>

    <div class="container hero-content">
      <div class="hero-badge reveal">
        <span class="badge-dot"></span>
        Comunidad activa en WhatsApp
      </div>

      <h1 class="hero-title reveal reveal-delay-1">
        Conectá con el<br />
        <span class="gradient-text">mundo digital</span>
      </h1>

      <p class="hero-subtitle reveal reveal-delay-2">
        Nexo Digital es la comunidad de WhatsApp para desarrolladores, diseñadores,
        creadores, músicos, gamers, especialistas en IA y todos los que construyen
        cosas en el ecosistema digital.
      </p>

      <div class="hero-actions reveal reveal-delay-3">
        <a href={WHATSAPP_LINK} id="hero-cta-primary" class="btn-primary" target="_blank" rel="noopener noreferrer">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
          </svg>
          Unirme a Nexo Digital
        </a>
        <a href="#presentacion" id="hero-cta-secondary" class="btn-secondary">
          Conocer más
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M12 5v14M5 12l7 7 7-7"/>
          </svg>
        </a>
      </div>

      <!-- Stats -->
      <div class="hero-stats reveal reveal-delay-4">
        <div class="stat">
          <span class="stat-value gradient-text">10+</span>
          <span class="stat-label">Áreas digitales</span>
        </div>
        <div class="stat-divider" aria-hidden="true"></div>
        <div class="stat">
          <span class="stat-value gradient-text">100%</span>
          <span class="stat-label">Sin jerarquías</span>
        </div>
        <div class="stat-divider" aria-hidden="true"></div>
        <div class="stat">
          <span class="stat-value gradient-text">∞</span>
          <span class="stat-label">Oportunidades</span>
        </div>
      </div>
    </div>

    <!-- Flecha scroll -->
    <a href="#presentacion" class="scroll-indicator" aria-label="Ir a la siguiente sección">
      <span></span><span></span>
    </a>
  </section>

  <!-- ===================== PRESENTACION ===================== -->
  <section id="presentacion" class="section-presentation">
    <div class="container">
      <div class="pres-grid">
        <div class="pres-visual reveal">
          <div class="logo-showcase">
            <div class="logo-glow-ring" aria-hidden="true"></div>
            <img src="/logo.png" alt="Logo de Nexo Digital" class="logo-big" width="200" height="200" />
          </div>
        </div>

        <div class="pres-text">
          <div class="section-badge reveal">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 14.5v-9l6 4.5-6 4.5z"/></svg>
            Presentación
          </div>
          <h2 class="section-title reveal reveal-delay-1">
            Una red real de<br/><span class="gradient-text">talento digital</span>
          </h2>
          <p class="section-subtitle reveal reveal-delay-2">
            Nexo Digital nació para conectar personas que trabajan o estudian dentro del
            ecosistema digital. Si te dedicás al desarrollo, diseño, edición, música,
            domótica, IA o cualquier disciplina creativa y tecnológica, este espacio es para vos.
          </p>
          <div class="pres-values reveal reveal-delay-3">
            <div class="value-pill">
              <span>🤝</span> Comunidad real
            </div>
            <div class="value-pill">
              <span>🚫</span> Sin jerarquías
            </div>
            <div class="value-pill">
              <span>🚀</span> Proyectos reales
            </div>
            <div class="value-pill">
              <span>🌐</span> Red amplia
            </div>
          </div>
          <p class="pres-quote reveal reveal-delay-4">
            <em>"No es un grupo más de WhatsApp lleno de spam. Es una red real de gente que construye cosas en el mundo digital."</em>
          </p>
        </div>
      </div>

      <!-- Áreas -->
      <div class="areas-grid">
        <h3 class="areas-title reveal">¿Para quién es Nexo Digital?</h3>
        <div class="areas-cards">
          {[
            { emoji: "💻", label: "Desarrollo web, apps y software" },
            { emoji: "🎨", label: "Diseño gráfico, UX/UI y multimedia" },
            { emoji: "🎬", label: "Edición de video y motion graphics" },
            { emoji: "🎧", label: "Producción musical y sonido" },
            { emoji: "🕹️", label: "Game dev" },
            { emoji: "🤖", label: "IA aplicada a creatividad" },
            { emoji: "🏠", label: "Domótica, automatización e IoT" },
            { emoji: "🖥️", label: "Informática y tecnología" },
            { emoji: "📱", label: "Creadores de contenido" },
            { emoji: "👥", label: "RRHH y Recruiters tech" },
          ].map((area, i) => (
            <div class={`area-card reveal reveal-delay-${(i % 5) + 1}`}>
              <span class="area-emoji" aria-hidden="true">{area.emoji}</span>
              <span class="area-label">{area.label}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ===================== OBJETIVOS ===================== -->
  <section id="objetivos" class="section-objectives">
    <div class="container">
      <div class="section-header centered">
        <div class="section-badge reveal">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2a10 10 0 100 20A10 10 0 0012 2zm1 17.93V18a1 1 0 00-2 0v1.93A8.001 8.001 0 014.07 13H6a1 1 0 000-2H4.07A8.001 8.001 0 0111 4.07V6a1 1 0 002 0V4.07A8.001 8.001 0 0119.93 11H18a1 1 0 000 2h1.93A8.001 8.001 0 0113 19.93z"/></svg>
          Objetivos
        </div>
        <h2 class="section-title reveal reveal-delay-1">
          ¿Qué vas a encontrar<br/><span class="gradient-text">en la comunidad?</span>
        </h2>
        <p class="section-subtitle reveal reveal-delay-2">
          Nexo Digital está construido para que cada miembro pueda crecer, conectar y aportar valor real.
        </p>
      </div>

      <div class="objectives-grid">
        {[
          {
            icon: `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="5" r="3"/><path d="M6.5 8a3 3 0 00-3 3v1h17v-1a3 3 0 00-3-3H6.5z"/><circle cx="3" cy="19" r="2"/><circle cx="12" cy="19" r="2"/><circle cx="21" cy="19" r="2"/><path d="M3 17v-2m9 2v-2m9 2v-2"/></svg>`,
            title: "Networking",
            desc: "Conectá con profesionales de todas las disciplinas del mundo digital.",
            color: "cyan",
          },
          {
            icon: `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 7V5a2 2 0 00-2-2h-4a2 2 0 00-2 2v2"/><line x1="12" y1="12" x2="12" y2="16"/><line x1="10" y1="14" x2="14" y2="14"/></svg>`,
            title: "Ofertas laborales",
            desc: "Accedé a oportunidades de empleo compartidas directamente por la comunidad.",
            color: "purple",
          },
          {
            icon: `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 19a2 2 0 01-2 2H4a2 2 0 01-2-2V5a2 2 0 012-2h5l2 3h9a2 2 0 012 2z"/></svg>`,
            title: "Recursos y herramientas",
            desc: "Intercambiá recursos útiles, tutoriales, repos y herramientas de la industria.",
            color: "magenta",
          },
          {
            icon: `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>`,
            title: "Mostrar proyectos",
            desc: "Compartí en lo que estás trabajando y recibí feedback de otros profesionales.",
            color: "indigo",
          },
          {
            icon: `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 014 4v14a3 3 0 00-3-3H2z"/><path d="M22 3h-6a4 4 0 00-4 4v14a3 3 0 013-3h7z"/></svg>`,
            title: "Aprendizaje colectivo",
            desc: "Toda pregunta suma, toda experiencia enseña. Sin importar tu nivel.",
            color: "cyan",
          },
          {
            icon: `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>`,
            title: "Conectar talento",
            desc: "Encontrá oportunidades reales donde el talento se conecta con quien lo busca.",
            color: "purple",
          },
        ].map((obj, i) => (
          <article class={`obj-card obj-${obj.color} reveal reveal-delay-${(i % 3) + 1}`}>
            <div class={`obj-icon obj-icon-${obj.color}`} set:html={obj.icon} aria-hidden="true" />
            <h3 class="obj-title">{obj.title}</h3>
            <p class="obj-desc">{obj.desc}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ===================== CANALES ===================== -->
  <section id="canales" class="section-channels">
    <div class="container">
      <div class="section-header centered">
        <div class="section-badge reveal">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20 2H4c-1.1 0-2 .9-2 2v18l4-4h14c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2z"/></svg>
          Canales organizados
        </div>
        <h2 class="section-title reveal reveal-delay-1">
          Todo tiene su<br/><span class="gradient-text">espacio propio</span>
        </h2>
        <p class="section-subtitle reveal reveal-delay-2">
          La comunidad está organizada en canales temáticos para que encuentres exactamente lo que buscás.
        </p>
      </div>

      <div class="channels-list reveal reveal-delay-3">
        {[
          { emoji: "💻", name: "Desarrollo", desc: "Web, apps, software, código" },
          { emoji: "🎨", name: "Diseño", desc: "Gráfico, UX/UI, multimedia" },
          { emoji: "🎬", name: "Edición y video", desc: "Motion graphics, post-producción" },
          { emoji: "🎧", name: "Audio y música", desc: "Producción musical, sonido" },
          { emoji: "🤖", name: "IA y herramientas", desc: "Inteligencia artificial, automatización" },
          { emoji: "🏠", name: "Domótica / IoT", desc: "Smart home, automatización" },
          { emoji: "💼", name: "Ofertas laborales", desc: "Empleos y oportunidades" },
          { emoji: "🚀", name: "Networking y proyectos", desc: "Colaboraciones y showcase" },
          { emoji: "📂", name: "Recursos", desc: "Herramientas, tutoriales, repos" },
        ].map(ch => (
          <div class="channel-item">
            <span class="channel-emoji" aria-hidden="true">{ch.emoji}</span>
            <div class="channel-info">
              <strong class="channel-name"># {ch.name}</strong>
              <span class="channel-desc">{ch.desc}</span>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===================== FILOSOFIA ===================== -->
  <section class="section-philosophy">
    <div class="container">
      <div class="philosophy-card reveal">
        <div class="philosophy-glow" aria-hidden="true"></div>
        <div class="philosophy-content">
          <p class="philosophy-label">La esencia de Nexo Digital</p>
          <h2 class="philosophy-title">
            No hay <span class="gradient-text">jerarquías.</span>
          </h2>
          <p class="philosophy-text">
            No es un espacio de "expertos vs principiantes". Es un lugar construido por la comunidad.
            Cada persona que entra aporta algo: una idea, una pregunta, un recurso, una experiencia.
          </p>
          <div class="philosophy-pillars">
            <div class="pillar"><span>💬</span> Toda opinión es válida</div>
            <div class="pillar"><span>🧠</span> Toda pregunta suma</div>
            <div class="pillar"><span>🚀</span> Toda persona puede aportar</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===================== INVITACION ===================== -->
  <section id="invitacion" class="section-invite">
    <div class="invite-bg" aria-hidden="true"></div>
    <div class="container">
      <div class="invite-content">
        <div class="invite-badge reveal">🌐 Bienvenido a Nexo Digital</div>
        <h2 class="invite-title reveal reveal-delay-1">
          Donde las ideas, el talento<br/>
          <span class="gradient-text">y la tecnología se conectan</span>
        </h2>
        <p class="invite-subtitle reveal reveal-delay-2">
          Si trabajás en tecnología, creatividad digital, domótica o reclutamiento en el sector, estás invitado.
          Y si conocés gente que también esté en este mundo, invitalaos también.
          Mientras más talentos haya, más oportunidades aparecen.
        </p>
        <div class="invite-actions reveal reveal-delay-3">
          <a href={WHATSAPP_LINK} id="invite-cta" class="btn-invite" target="_blank" rel="noopener noreferrer">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
            </svg>
            Unirme a la comunidad
          </a>
          <p class="invite-note">Gratis · Sin spam · Solo tecnología y creatividad</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===================== FOOTER ===================== -->
  <footer class="footer">
    <div class="container footer-inner">
      <div class="footer-logo">
        <img src="/logo.png" alt="Logo Nexo Digital" width="32" height="32" />
        <span>Nexo <span class="gradient-text">Digital</span></span>
      </div>
      <p class="footer-copy">© 2025 Nexo Digital · Comunidad para creadores del mundo digital</p>
      <nav class="footer-links" aria-label="Links del footer">
        <a href="#presentacion">Presentación</a>
        <a href="#objetivos">Objetivos</a>
        <a href="#invitacion">Invitación</a>
      </nav>
    </div>
  </footer>
</Layout>

<style>
  /* -------- HERO -------- */
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 8rem 1.5rem 6rem;
    overflow: hidden;
    text-align: center;
  }

  .hero-canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
    opacity: 0.6;
  }

  .hero-glow {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -60%);
    width: 700px;
    height: 700px;
    background: radial-gradient(circle, rgba(168,85,247,0.18) 0%, rgba(0,245,255,0.08) 40%, transparent 70%);
    border-radius: 50%;
    z-index: 0;
    pointer-events: none;
    animation: pulseGlow 6s ease-in-out infinite;
  }

  @keyframes pulseGlow {
    0%, 100% { opacity: 0.8; transform: translate(-50%, -60%) scale(1); }
    50% { opacity: 1; transform: translate(-50%, -60%) scale(1.08); }
  }

  .hero-content {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.4rem 1.1rem;
    border-radius: 100px;
    background: rgba(0, 245, 255, 0.08);
    border: 1px solid rgba(0, 245, 255, 0.25);
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--cyan);
    letter-spacing: 0.05em;
  }

  .badge-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--cyan);
    box-shadow: 0 0 8px var(--cyan);
    animation: blink 2s ease-in-out infinite;
  }

  @keyframes blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.3; }
  }

  .hero-title {
    font-family: var(--font-display);
    font-size: clamp(2.8rem, 8vw, 5.5rem);
    font-weight: 900;
    line-height: 1.05;
    letter-spacing: -0.03em;
    color: var(--text-primary);
    max-width: 800px;
  }

  .hero-subtitle {
    font-size: clamp(1rem, 2vw, 1.2rem);
    color: var(--text-secondary);
    max-width: 600px;
    line-height: 1.8;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    justify-content: center;
    margin-top: 0.5rem;
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    padding: 0.85rem 1.8rem;
    border-radius: 100px;
    background: linear-gradient(135deg, #25d366, #128c7e);
    color: #fff;
    font-weight: 700;
    font-size: 1rem;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
    box-shadow: 0 6px 30px rgba(37, 211, 102, 0.35);
  }

  .btn-primary:hover {
    transform: translateY(-2px) scale(1.02);
    box-shadow: 0 10px 40px rgba(37, 211, 102, 0.5);
  }

  .btn-secondary {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.85rem 1.8rem;
    border-radius: 100px;
    border: 1.5px solid rgba(168, 85, 247, 0.4);
    color: var(--text-secondary);
    font-weight: 600;
    font-size: 1rem;
    background: rgba(168, 85, 247, 0.06);
    transition: all 0.3s ease;
  }

  .btn-secondary:hover {
    border-color: var(--purple);
    color: var(--text-primary);
    background: rgba(168, 85, 247, 0.12);
  }

  .hero-stats {
    display: flex;
    align-items: center;
    gap: 2rem;
