---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/layout/Navbar.astro';
import Footer from '../components/layout/Footer.astro';
import ResourceCard from '../components/resources/ResourceCard.astro';
import FilterBar from '../components/ui/FilterBar.astro';
import logoImg from '../assets/logo.webp';
import resourcesData from '../data/resources.json';

const GITHUB_REPO = "https://github.com/Shinigamy19/Nexo-Digital";
const NEW_RESOURCE_URL = `${GITHUB_REPO}/issues/new?template=nuevo_recurso.md&title=%5BRECURSO%5D+Nombre+del+recurso&labels=recurso,pendiente-revision`;

const typeOptions = [
  { value: 'herramienta',   label: '🔧 Herramienta' },
  { value: 'tutorial',      label: '📖 Tutorial' },
  { value: 'recurso',       label: '🔗 Recurso' },
  { value: 'template',      label: '📄 Template' },
  { value: 'documentación', label: '📚 Docs' },
];
---

<Layout
  title="Recursos — Nexo Digital"
  description="Biblioteca de recursos curada por la comunidad de Nexo Digital: herramientas, tutoriales, templates, repositorios y documentación para el mundo digital."
>
  <Navbar />

  <main>
    <section class="resources-hero">
      <div class="container">
        <div class="section-badge reveal">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
          Recursos
        </div>
        <h1 class="section-title reveal reveal-delay-1">
          Biblioteca de<br/><span class="gradient-text">recursos</span>
        </h1>
        <p class="section-subtitle reveal reveal-delay-2">
          Herramientas, tutoriales, templates y recursos seleccionados y recomendados por la comunidad. Todo en un solo lugar.
        </p>

        <div class="hero-actions reveal reveal-delay-3">
          <a href={NEW_RESOURCE_URL} class="btn-submit" target="_blank" rel="noopener noreferrer" id="resources-submit-btn">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
            Sugerir un recurso
          </a>
          <span class="moderation-note">
            <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            Revisado por moderadores antes de publicarse
          </span>
        </div>
      </div>
    </section>

    <section class="resources-list">
      <div class="container">
        <div class="list-header reveal">
          <div class="results-info">
            <span class="results-count">{resourcesData.length} recurso{resourcesData.length !== 1 ? 's' : ''}</span>
          </div>
          <FilterBar id="resources" options={typeOptions} allLabel="Todos los tipos" />
        </div>

        <div class="resources-grid">
          {resourcesData.map((resource, i) => (
            <div
              data-category={resource.type}
              data-filtergroup="resources"
              class={`reveal reveal-delay-${(i % 3) + 1}`}
            >
              <ResourceCard {...resource} />
            </div>
          ))}
        </div>

        <div class="contribute-cta reveal">
          <div class="cta-inner">
            <span class="cta-icon" aria-hidden="true">📚</span>
            <div class="cta-text">
              <strong>¿Conocés un recurso que debería estar acá?</strong>
              <p>Abrí un Issue en GitHub con el link y descripción. Los moderadores lo revisarán y agregarán si cumple los criterios de calidad.</p>
            </div>
            <a href={NEW_RESOURCE_URL} class="cta-link" target="_blank" rel="noopener noreferrer">
              Sugerir recurso
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </a>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer logoImg={logoImg} />
</Layout>

<script>
  const revealEls = document.querySelectorAll('.reveal');
  const observer = new IntersectionObserver(
    entries => entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); }),
    { threshold: 0.1 }
  );
  revealEls.forEach(el => observer.observe(el));
</script>

<style>
  .resources-hero {
    padding-top: 10rem;
    padding-bottom: 3rem;
    text-align: center;
  }
  .resources-hero .section-badge { margin-bottom: 1.5rem; }
  .resources-hero .section-subtitle { margin: 0 auto 2rem; }

  .hero-actions {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
  }
  .btn-submit {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.7rem 1.6rem;
    border-radius: 12px;
    background: var(--gradient-main);
    color: #fff;
    font-weight: 700;
    font-size: 0.95rem;
    text-decoration: none;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
    box-shadow: 0 4px 20px rgba(0, 245, 255, 0.3);
  }
  .btn-submit:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 32px rgba(0, 245, 255, 0.5);
  }
  .moderation-note {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.78rem;
    color: var(--text-muted);
  }

  .resources-list { padding-top: 1rem; }

  .list-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1rem;
    margin-bottom: 2.5rem;
  }
  .results-count {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--text-muted);
  }

  .resources-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.25rem;
  }

  .contribute-cta { margin-top: 4rem; margin-bottom: 2rem; }
  .cta-inner {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    background: var(--bg-card);
    border: 1px solid rgba(0, 245, 255, 0.15);
    border-radius: 16px;
    padding: 1.5rem 2rem;
    flex-wrap: wrap;
  }
  .cta-icon { font-size: 2rem; flex-shrink: 0; }
  .cta-text { flex: 1; min-width: 200px; }
  .cta-text strong { display: block; color: var(--text-primary); font-size: 1rem; margin-bottom: 0.3rem; }
  .cta-text p { font-size: 0.85rem; color: var(--text-secondary); line-height: 1.6; }
  .cta-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-weight: 700;
    font-size: 0.88rem;
    color: var(--cyan);
    text-decoration: none;
    padding: 0.55rem 1.2rem;
    border: 1px solid rgba(0, 245, 255, 0.3);
    border-radius: 10px;
    background: rgba(0, 245, 255, 0.06);
    transition: all 0.2s ease;
    white-space: nowrap;
  }
  .cta-link:hover {
    background: rgba(0, 245, 255, 0.15);
    border-color: rgba(0, 245, 255, 0.6);
    color: var(--text-primary);
  }

  @media (max-width: 768px) {
    .list-header { flex-direction: column; align-items: flex-start; }
    .cta-inner { flex-direction: column; align-items: flex-start; }
  }
</style>
