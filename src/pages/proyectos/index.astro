---
export const prerender = false;

import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/layout/Navbar/index.astro';
import Footer from '../../components/layout/Footer/index.astro';
import ProjectsHero from '../../components/projects/ProjectsHero/index.astro';
import ProjectsList from '../../components/projects/ProjectsList/index.astro';
import logoImg from '../../assets/brand/logo.webp';
import projectsData from '../../data/projects.json';
import { prisma } from '../../lib/prisma';

const NEW_PROJECT_URL = '/proyectos/nuevo';

const filterOptions = [
  { value: 'desarrollo', label: '💻 Desarrollo' },
  { value: 'diseno',     label: '🎨 Diseño' },
  { value: 'ia',         label: '🤖 IA' },
  { value: 'iot',        label: '🏠 IoT' },
  { value: 'edicion',    label: '🎦 Edición' },
  { value: 'audio',      label: '🎧 Audio' },
  { value: 'gamedev',    label: '🕹️ Game Dev' },
];

let data = projectsData;

try {
  const dbProjects = await prisma.project.findMany({
    where: { status: 'approved' },
    orderBy: [{ featured: 'desc' }, { createdAt: 'desc' }],
    take: 100,
    select: {
      id: true,
      title: true,
      description: true,
      category: true,
      technologies: true,
      authorName: true,
      authorGithub: true,
      repo: true,
      demo: true,
      projectStatus: true,
      featured: true,
      projectType: true,
      mediaUrls: true,
      socialLinks: true,
      collaborative: true,
    },
  });

  if (dbProjects.length > 0) {
    data = dbProjects.map(p => ({
      id: p.id,
      title: p.title,
      description: p.description,
      category: p.category,
      technologies: p.technologies,
      author: p.authorName,
      authorGithub: p.authorGithub ?? '',
      repo: p.repo ?? '',
      demo: p.demo ?? '',
      status: p.projectStatus === 'en_progreso' ? 'en progreso' : p.projectStatus,
      featured: p.featured,
      projectType: p.projectType ?? 'desarrollo',
      mediaUrls: p.mediaUrls ?? [],
      socialLinks: (() => {
        try { return JSON.parse(p.socialLinks as string); }
        catch { return []; }
      })(),
      collaborative: p.collaborative,
    }));
  }
} catch {}
---

<Layout
  title="Proyectos — Nexo Digital"
  description="Biblioteca de proyectos open source impulsados por la comunidad de Nexo Digital. Desarrolladores, diseñadores, creadores y makers compartiendo sus creaciones."
>
  <Navbar />

  <main>
    <ProjectsHero submitUrl={NEW_PROJECT_URL} />

    <ProjectsList
      projectsData={data}
      filterOptions={filterOptions}
      submitUrl={NEW_PROJECT_URL}
    />
  </main>

  <Footer />
</Layout>

<script>
  import { initRevealObserver } from '../../scripts/reveal';
  initRevealObserver();
</script>
