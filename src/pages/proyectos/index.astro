---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/layout/Navbar/index.astro';
import Footer from '../../components/layout/Footer/index.astro';
import ProjectCard from '../../components/projects/ProjectCard/index.astro';
import FilterBar from '../../components/ui/FilterBar/index.astro';
import logoImg from '../../assets/brand/logo.webp';
import projectsData from '../../data/projects.json';
import styles from './proyectos.module.css';

const GITHUB_REPO = "https://github.com/NexoDigital-Lab/Nexo-Digital";
const NEW_PROJECT_URL = `${GITHUB_REPO}/issues/new?template=nuevo_proyecto.md&title=%5BPROYECTO%5D+Nombre+de+tu+proyecto&labels=proyecto,pendiente-revision`;

const filterOptions = [
  { value: 'desarrollo', label: '💻 Desarrollo' },
  { value: 'diseño',     label: '🎨 Diseño' },
  { value: 'ia',         label: '🤖 IA' },
  { value: 'iot',        label: '🏠 IoT' },
  { value: 'edicion',    label: '🎦 Edición' },
  { value: 'audio',      label: '🎧 Audio' },
  { value: 'gamedev',    label: '🕹️ Game Dev' },
];
---

<Layout
  title="Proyectos — Nexo Digital"
  description="Biblioteca de proyectos open source impulsados por la comunidad de Nexo Digital. Desarrolladores, diseñadores, creadores y makers compartiendo sus creaciones."
>
  <Navbar />

  <main>
    <section class={styles['projects-hero']}>
      <div class="container">
        <div class="section-badge reveal">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
          Open Source
        </div>
        <h1 class="section-title reveal reveal-delay-1">
          Proyectos de la<br/><span class="gradient-text">comunidad</span>
        </h1>
        <p class="section-subtitle reveal reveal-delay-2">
          Proyectos reales construidos por miembros de Nexo Digital. Explorá, contribuí y mostrá lo que vos también estás construyendo.
        </p>

        <div class={`${styles['hero-actions']} reveal reveal-delay-3`}>
          <a href={NEW_PROJECT_URL} class={styles['btn-submit']} target="_blank" rel="noopener noreferrer" id="projects-submit-btn">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
            Agregar mi proyecto
          </a>
          <span class={styles['moderation-note']}>
            <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            Revisado por moderadores antes de publicarse
          </span>
        </div>
      </div>
    </section>

    <section class={styles['projects-list']}>
      <div class="container">
        <div class={`${styles['list-header']} reveal`}>
          <div>
            <span class={styles['results-count']}>{projectsData.length} proyecto{projectsData.length !== 1 ? 's' : ''}</span>
          </div>
          <FilterBar id="projects" options={filterOptions} />
        </div>

        <div class={styles['projects-grid']}>
          {projectsData.map((project, i) => (
            <div
              data-category={project.category}
              data-filtergroup="projects"
              class={`reveal reveal-delay-${(i % 3) + 1}`}
            >
              <ProjectCard {...project} />
            </div>
          ))}
        </div>

        <div class={`${styles['contribute-cta']} reveal`}>
          <div class={styles['cta-inner']}>
            <span class={styles['cta-icon']} aria-hidden="true">🚀</span>
            <div class={styles['cta-text']}>
              <strong>¿Tenés un proyecto para mostrar?</strong>
              <p>Abrí un Issue en GitHub con los datos de tu proyecto y un moderador lo revisará en 24–48hs.</p>
            </div>
            <a href={NEW_PROJECT_URL} class={styles['cta-link']} target="_blank" rel="noopener noreferrer">
              Proponer proyecto
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </a>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer logoImg={logoImg} />
</Layout>

<script>
  const revealEls = document.querySelectorAll('.reveal');
  const observer = new IntersectionObserver(
    entries => entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); }),
    { threshold: 0.1 }
  );
  revealEls.forEach(el => observer.observe(el));
</script>


