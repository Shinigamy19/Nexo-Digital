---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Nexo Digital — Comunidad para creadores del mundo digital",
  description = "Nexo Digital es una comunidad de WhatsApp para desarrolladores, diseñadores, editores, músicos, creadores de contenido y profesionales de la tecnología. Conecta, comparte y crece.",
} = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta name="theme-color" content="#0a0a0f" />
    <link rel="icon" type="image/webp" href="/favicons/logo.webp" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Outfit:wght@400;600;700;800;900&display=swap"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Outfit:wght@400;600;700;800;900&display=swap"
      rel="stylesheet"
      media="print"
      onload="this.media='all'"
    />
    <noscript>
      <link
        href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Outfit:wght@400;600;700;800;900&display=swap"
        rel="stylesheet"
      />
    </noscript>
    <title>{title}</title>
  </head>
  <body>
    <slot />
    <script is:inline>
      (function() {
        document.addEventListener('click', function(e) {
          var target = e.target;

          var trigger = target.closest ? target.closest('[data-modal-trigger]') : null;
          if (trigger) {
            var id = trigger.getAttribute('data-modal-trigger');
            var overlay = document.getElementById(id);
            if (overlay) {
              document.body.appendChild(overlay);
              overlay.classList.add('open');
              document.body.style.overflow = 'hidden';
            }
            return;
          }

          var closeBtn = target.closest ? target.closest('[data-modal-close]') : null;
          if (closeBtn) {
            var el = target;
            while (el && el.parentNode) {
              if (el.hasAttribute && el.hasAttribute('data-modal-overlay')) {
                el.classList.remove('open');
                document.body.style.overflow = '';
                return;
              }
              el = el.parentNode;
            }
            return;
          }

          if (target.hasAttribute && target.hasAttribute('data-modal-overlay')) {
            target.classList.remove('open');
            document.body.style.overflow = '';
          }
        });

        document.addEventListener('keydown', function(e) {
          if (e.key === 'Escape') {
            var overlays = document.querySelectorAll('[data-modal-overlay].open');
            for (var i = 0; i < overlays.length; i++) {
              overlays[i].classList.remove('open');
            }
            document.body.style.overflow = '';
          }
        });
      })();
    </script>
  </body>
</html>
