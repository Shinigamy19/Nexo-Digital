---
import styles from './SearchBar.module.css';

interface Props {
  id?: string;
  placeholder?: string;
}

const { id = 'search-bar', placeholder = 'Buscar…' } = Astro.props;
---

<div class={styles.wrapper}>
  <svg class={styles.icon} xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
  <input class={styles.input} type="text" id={id} placeholder={placeholder} autocomplete="off" />
</div>
