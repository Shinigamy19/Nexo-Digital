---
import type { ModerationStatus } from '../../types/database';
import { MODERATION_STATUS_LABELS } from '../../lib/portal-meta';

interface Props {
  status: ModerationStatus;
  size?: 'sm' | 'md';
}

const { status, size = 'md' } = Astro.props as Props;
const meta = MODERATION_STATUS_LABELS[status];
---

<span class={`status-badge status-${status} size-${size}`} data-status={status}>
  <span aria-hidden="true" class="emoji">{meta.emoji}</span>
  <span class="label">{meta.label}</span>
</span>

<style>
  .status-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    border-radius: 100px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    white-space: nowrap;
    line-height: 1;
  }
  .size-md { font-size: 0.72rem; padding: 0.32rem 0.7rem; }
  .size-sm { font-size: 0.62rem; padding: 0.22rem 0.55rem; }
  .emoji { font-size: 0.85em; }

  .status-pending {
    background: rgba(250, 204, 21, 0.12);
    color: #fbbf24;
    border: 1px solid rgba(250, 204, 21, 0.35);
  }
  .status-approved {
    background: rgba(34, 197, 94, 0.12);
    color: #4ade80;
    border: 1px solid rgba(34, 197, 94, 0.35);
  }
  .status-rejected {
    background: rgba(248, 113, 113, 0.12);
    color: #f87171;
    border: 1px solid rgba(248, 113, 113, 0.35);
  }
  .status-removed {
    background: rgba(154, 154, 176, 0.12);
    color: var(--text-muted, #9a9ab0);
    border: 1px solid rgba(154, 154, 176, 0.35);
  }
</style>
