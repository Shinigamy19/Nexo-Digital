---
import styles from './Hero.module.css';

interface Props {
  whatsappLink: string;
}

const { whatsappLink } = Astro.props;
---

<section id="inicio" class={styles.hero}>
  <!-- Fondo animado de partículas/red -->
  <canvas id="heroCanvas" class={styles['hero-canvas']} aria-hidden="true"></canvas>

  <!-- Halo de brillo central -->
  <div class={styles['hero-glow']} aria-hidden="true"></div>

  <div class={`container ${styles['hero-content']}`}>
    <div class={`${styles['hero-badge']} reveal`}>
      <span class={styles['badge-dot']}></span>
      Comunidad activa en WhatsApp
    </div>

    <h1 class={`${styles['hero-title']} reveal reveal-delay-1`}>
      Conectá con el<br />
      <span class="gradient-text">mundo digital</span>
    </h1>

    <p class={`${styles['hero-subtitle']} reveal reveal-delay-2`}>
      Nexo Digital es la comunidad de WhatsApp para desarrolladores, diseñadores,
      creadores, músicos, gamers, especialistas en IA y todos los que construyen
      cosas en el ecosistema digital.
    </p>

    <div class={`${styles['hero-actions']} reveal reveal-delay-3`}>
      <a href={whatsappLink} id="hero-cta-primary" class={styles['btn-primary']} target="_blank" rel="noopener noreferrer">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
        </svg>
        Unirme a Nexo Digital
      </a>
      <a href="#presentacion" id="hero-cta-secondary" class={styles['btn-secondary']}>
        Conocer más
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M12 5v14M5 12l7 7 7-7"/>
        </svg>
      </a>
    </div>

    <!-- Stats -->
    <div class={`${styles['hero-stats']} reveal reveal-delay-4`}>
      <div class={styles.stat}>
        <span class={`${styles['stat-value']} gradient-text`}>10+</span>
        <span class={styles['stat-label']}>Áreas digitales</span>
      </div>
      <div class={styles['stat-divider']} aria-hidden="true"></div>
      <div class={styles.stat}>
        <span class={`${styles['stat-value']} gradient-text`}>100%</span>
        <span class={styles['stat-label']}>Sin jerarquías</span>
      </div>
      <div class={styles['stat-divider']} aria-hidden="true"></div>
      <div class={styles.stat}>
        <span class={`${styles['stat-value']} gradient-text`}>∞</span>
        <span class={styles['stat-label']}>Oportunidades</span>
      </div>
    </div>
  </div>

  <!-- Flecha scroll -->
  <a href="#presentacion" class={styles['scroll-indicator']} aria-label="Ir a la siguiente sección">
    <span></span><span></span>
  </a>
</section>

<script>
  // ---- Canvas particle network (Hero) con optimizaciones ----
  const initCanvas = () => {
    const canvas = document.getElementById('heroCanvas') as HTMLCanvasElement;
    if (!canvas) return;
    
    const ctx = canvas.getContext('2d')!;
    let W: number, H: number;
    let particles: Particle[] = [];
    
    type Particle = { x: number; y: number; vx: number; vy: number; color: string; r: number };
    const COLORS = ['#00f5ff', '#a855f7', '#ff2d78'];
    
    function setSize() {
      W = canvas.width = window.innerWidth;
      H = canvas.height = window.innerHeight;
      const NUM = Math.floor((W * H) / 18000);
      particles = Array.from({ length: NUM }, () => ({
        x: Math.random() * W,
        y: Math.random() * H,
        vx: (Math.random() - 0.5) * 0.4,
        vy: (Math.random() - 0.5) * 0.4,
        color: COLORS[Math.floor(Math.random() * COLORS.length)],
        r: Math.random() * 2 + 1,
      }));
    }
    
    setSize();

    function drawParticles() {
      ctx.clearRect(0, 0, W, H);
      for (let i = 0; i < particles.length; i++) {
        const p = particles[i];
        p.x += p.vx;
        p.y += p.vy;
        if (p.x < 0 || p.x > W) p.vx *= -1;
        if (p.y < 0 || p.y > H) p.vy *= -1;

        ctx.beginPath();
        ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2);
        ctx.fillStyle = p.color;
        ctx.globalAlpha = 0.7;
        ctx.fill();
        ctx.globalAlpha = 1;

        for (let j = i + 1; j < particles.length; j++) {
          const q = particles[j];
          const dx = p.x - q.x;
          const dy = p.y - q.y;
          const distSq = dx * dx + dy * dy;
          
          if (distSq < 16900) { // 130^2
            const dist = Math.sqrt(distSq);
            ctx.beginPath();
            ctx.moveTo(p.x, p.y);
            ctx.lineTo(q.x, q.y);
            ctx.strokeStyle = p.color;
            ctx.globalAlpha = (1 - dist / 130) * 0.15;
            ctx.lineWidth = 0.8;
            ctx.stroke();
            ctx.globalAlpha = 1;
          }
        }
      }
      requestAnimationFrame(drawParticles);
    }
    
    drawParticles();

    let resizeTimer: number;
    window.addEventListener('resize', () => {
      clearTimeout(resizeTimer);
      resizeTimer = window.setTimeout(setSize, 250);
    }, { passive: true });
  };

  // Esperar a que el hilo principal esté libre para no impactar el LCP inicial
  if (document.readyState === 'complete') {
    initCanvas();
  } else {
    window.addEventListener('load', initCanvas, { once: true });
  }
</script>
