---
import styles from "./ProjectsList.module.css";
import FilterBar from "../../ui/FilterBar/index.astro";
import SearchBar from "../../ui/SearchBar/index.astro";
import Paginator from "../../ui/Paginator/index.astro";
import ProjectCard from "../ProjectCard/index.astro";

interface Props {
  projectsData: Array<any>;
  filterOptions: Array<{ value: string; label: string }>;
  submitUrl: string;
}

const { projectsData, filterOptions, submitUrl } = Astro.props;
---

<section class={styles["projects-list"]}>
  <div class="container">
    <div class={`${styles["list-header"]} reveal`}>
      <div>
        <span class={styles["results-count"]}
          >{projectsData.length} proyecto{
            projectsData.length !== 1 ? "s" : ""
          }</span
        >
      </div>
      <div class={styles["controls"]}>
        <SearchBar placeholder="Buscar proyecto…" />
        <FilterBar id="projects" options={filterOptions} />
      </div>
    </div>

    <div class={styles["projects-grid"]} id="projects-grid">
      {
        projectsData.map((project, i) => (
          <div
            data-pag-item
            data-search-title={project.title?.toLowerCase() ?? ''}
            data-search-description={project.description?.toLowerCase() ?? ''}
            data-filter-projects={project.category}
            class={`reveal reveal-delay-${(i % 3) + 1}`}
          >
            <ProjectCard {...project} />
          </div>
        ))
      }
    </div>

    {projectsData.length > 0 && <Paginator id="projects-paginator" />}

    <div class={`${styles["contribute-cta"]} reveal`}>
      <div class={styles["cta-inner"]}>
        <span class={styles["cta-icon"]} aria-hidden="true">🚀</span>
        <div class={styles["cta-text"]}>
          <strong>¿Tenés un proyecto para mostrar?</strong>
          <p>
            Abrí un Issue en GitHub con los datos de tu proyecto <strong>(recordá aclarar las tecnologías utilizadas)</strong> 
            y un moderador lo revisará en 24–48hs. <br />
            <a href="https://github.com/NexoDigital-Lab/Nexo-Digital/blob/main/.github/ISSUE_TEMPLATE/nuevo_proyecto.md" class={styles["template-link"]} target="_blank" rel="noopener noreferrer">
              Ver plantilla de ejemplo →
            </a>
          </p>
        </div>
        <a
          href={submitUrl}
          class={styles["cta-link"]}
          target="_blank"
          rel="noopener noreferrer"
        >
          Proponer proyecto
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="14"
            height="14"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="M5 12h14"></path>
            <path d="m12 5 7 7-7 7"></path>
          </svg>
        </a>
      </div>
    </div>
  </div>
</section>

<script>
  import { initRevealObserver } from '../../../scripts/reveal';
  import { initListingControls } from '../../ui/listing-controls';

  initRevealObserver();
  initListingControls('projects-grid', ['searchTitle', 'searchDescription']);
</script>
