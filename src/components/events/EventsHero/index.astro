---
import styles from './EventsHero.module.css';

interface Props {
  publishUrl: string;
}

const { publishUrl } = Astro.props;
---

<section class={styles.hero}>
  <div class="container">
    <div class="section-badge reveal">
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
        <line x1="16" y1="2" x2="16" y2="6"/>
        <line x1="8" y1="2" x2="8" y2="6"/>
        <line x1="3" y1="10" x2="21" y2="10"/>
      </svg>
      Comunidad
    </div>
    <h1 class="section-title reveal reveal-delay-1">
      Eventos de la<br/><span class="gradient-text">comunidad</span>
    </h1>
    <p class="section-subtitle reveal reveal-delay-2">
      Workshops, hackathons, meetups y más. Participá, aprendé y conectá con otros profesionales digitales.
    </p>

    <div class={`${styles.actions} reveal reveal-delay-3`}>
      <a href={publishUrl} class={styles.btnPublish} id="events-publish-btn">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="12" y1="5" x2="12" y2="19"/>
          <line x1="5" y1="12" x2="19" y2="12"/>
        </svg>
        Publicar evento
      </a>
      <span class={styles.moderationNote}>
        <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
        </svg>
        Revisado por moderadores antes de publicarse
      </span>
    </div>
  </div>
</section>
