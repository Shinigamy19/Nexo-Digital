---
import styles from "./EventsList.module.css";
import FilterBar from "../../ui/FilterBar/index.astro";
import SearchBar from "../../ui/SearchBar/index.astro";
import Paginator from "../../ui/Paginator/index.astro";
import EventCard from "../EventCard/index.astro";

interface Props {
  eventsData: Array<any>;
  filterOptions: Array<{ value: string; label: string }>;
  publishUrl: string;
}

const { eventsData, filterOptions, publishUrl } = Astro.props;
---

<section class={styles.list} id="listado-eventos">
  <div class="container">
    <div class={`${styles.header} reveal`}>
      <div>
        <span class={styles.count}
          >{eventsData.length} evento{
            eventsData.length !== 1 ? "s" : ""
          }</span
        >
      </div>
      <div class={styles.controls}>
        <SearchBar placeholder="Buscar evento…" />
        <FilterBar id="events" options={filterOptions} />
      </div>
    </div>

    <div class={styles.grid} id="events-grid">
      {
        eventsData.map((event, i) => (
          <div
            data-pag-item
            data-search-title={event.title?.toLowerCase() ?? ''}
            data-search-description={event.description?.toLowerCase() ?? ''}
            data-filter-events={event.event_type}
            class={`reveal reveal-delay-${(i % 3) + 1}`}
          >
            <EventCard {...event} />
          </div>
        ))
      }
    </div>

    {eventsData.length > 0 && <Paginator id="events-paginator" />}

    {eventsData.length === 0 && (
      <div class={styles.empty}>
        <p>No hay eventos publicados todavía.</p>
        <a href={publishUrl} class={styles.emptyLink}>Publicar el primero</a>
      </div>
    )}
  </div>
</section>

<script>
  import { initRevealObserver } from '../../../scripts/reveal';
  import { initListingControls } from '../../ui/listing-controls';

  initRevealObserver();
  initListingControls('events-grid', ['searchTitle', 'searchDescription']);
</script>
