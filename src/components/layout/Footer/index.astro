---
import styles from './Footer.module.css';
---

<footer class={styles.footer}>
  <div class={`container ${styles['footer-inner']}`}>
    <div class={styles['footer-logo']}>
      <img src="/logo.webp" alt="Logo Nexo Digital" width={32} height={32} />
      <span>Nexo <span class="gradient-text">Digital</span></span>
    </div>
    <p class={styles['footer-copy']}>&copy; 2025 Nexo Digital &middot; Comunidad para creadores del mundo digital</p>
    <nav style="display:flex;gap:1.5rem;margin-top:0.5rem;">
      <a href="/terminos" style="font-size:0.82rem;color:var(--text-muted);text-decoration:none;transition:color 0.15s;">Términos y Condiciones</a>
    </nav>
  </div>
</footer>
