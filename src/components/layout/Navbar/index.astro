---
import { Image } from 'astro:assets';
import logoImg from '../../../assets/brand/logo.webp';
import styles from './Navbar.module.css';
---
<header class={styles.navbar} id="navbar" data-scrolled-class={styles.scrolled} data-menu-open-class={styles.menuOpen}>
  <div class={styles.navContainer}>
    <a href="#inicio" class={styles.navLogo} aria-label="Nexo Digital inicio">
      <Image src={logoImg} alt="Nexo Digital logo" width={38} height={38} loading="eager" fetchpriority="high" />
      <span class={styles.navLogoText}>Nexo <span class="gradient-text">Digital</span></span>
    </a>

    <button class={styles.navToggle} id="navToggle" aria-label="Abrir menú" aria-expanded="false" data-open-class={styles.open}>
      <span></span><span></span><span></span>
    </button>

    <nav class={styles.navLinks} id="navLinks" role="navigation" data-open-class={styles.open}>
      <a href="/#presentacion" class={styles.navLink}>Presentación</a>
      <a href="/#objetivos" class={styles.navLink}>Objetivos</a>
      <a href="/proyectos" class={styles.navLink}>Proyectos</a>
      <a href="/recursos" class={styles.navLink}>Recursos</a>
      <a href="/empleos" class={styles.navLink}>Empleos</a>
      <a href="/#invitacion" class={styles.navCta}>Unirme ahora</a>
    </nav>
  </div>
</header>




<script>
  const navbar = document.getElementById('navbar');
  const toggle = document.getElementById('navToggle');
  const navLinks = document.getElementById('navLinks');

  // Leer clases hasheadas desde data-attributes
  const scrolledClass = navbar?.dataset.scrolledClass ?? 'scrolled';
  const menuOpenClass = navbar?.dataset.menuOpenClass ?? 'menuOpen';
  const openClass = toggle?.dataset.openClass ?? 'open';

  // Scroll effect with optimization
  let ticking = false;
  window.addEventListener('scroll', () => {
    if (!ticking) {
      window.requestAnimationFrame(() => {
        if (window.scrollY > 30) {
          navbar?.classList.add(scrolledClass);
        } else {
          navbar?.classList.remove(scrolledClass);
        }
        ticking = false;
      });
      ticking = true;
    }
  }, { passive: true });

  // Mobile toggle
  toggle?.addEventListener('click', () => {
    const isOpen = toggle.classList.toggle(openClass);
    navLinks?.classList.toggle(openClass, isOpen);
    navbar?.classList.toggle(menuOpenClass, isOpen);
    toggle.setAttribute('aria-expanded', String(isOpen));
    document.body.style.overflow = isOpen ? 'hidden' : '';
  });

  // Close on link click
  navLinks?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => {
      toggle?.classList.remove(openClass);
      navLinks?.classList.remove(openClass);
      navbar?.classList.remove(menuOpenClass);
      toggle?.setAttribute('aria-expanded', 'false');
      document.body.style.overflow = '';
    });
  });
</script>
