---
import styles from './ResourceCard.module.css';
import modal from '../../shared/CardModal.module.css';

interface Props {
  id: string;
  title: string;
  description: string;
  type: string;
  category: string;
  url: string;
  mediaUrls?: string[];
  tags: string[];
  addedBy: string;
}

const { id, title, description, type, category, url, mediaUrls = [], tags, addedBy } = Astro.props;

const typeIcons: Record<string, string> = {
  herramienta: '🔧',
  tutorial: '📖',
  recurso: '🔗',
  template: '📄',
  documentación: '📚',
};

const typeColorMap: Record<string, string> = {
  herramienta: 'type-tool',
  tutorial: 'type-tutorial',
  recurso: 'type-resource',
  template: 'type-template',
  documentación: 'type-docs',
};

const categoryLabels: Record<string, string> = {
  desarrollo: '💻 Desarrollo',
  diseno: '🎨 Diseño',
  ia: '🤖 IA',
  iot: '🏠 IoT',
  edicion: '🎬 Edición',
  audio: '🎧 Audio',
  aprendizaje: '📚 Aprendizaje',
  marketing: '📣 Marketing',
  negocios: '💼 Negocios',
};

const categoryColorClass: Record<string, string> = {
  desarrollo: 'cat-dev',
  diseno: 'cat-design',
  ia: 'cat-ai',
  iot: 'cat-iot',
  edicion: 'cat-edit',
  audio: 'cat-audio',
  aprendizaje: 'cat-learn',
  marketing: 'cat-mkt',
  negocios: 'cat-biz',
};

function isYouTubeUrl(url: string): boolean {
  return /(?:youtube\.com\/watch\?v=|youtu\.be\/|youtube\.com\/embed\/)/.test(url);
}

function getYouTubeEmbed(url: string): string {
  const match = url.match(/(?:youtube\.com\/watch\?v=|youtu\.be\/|youtube\.com\/embed\/)([^&?#]+)/);
  return match ? `https://www.youtube.com/embed/${match[1]}` : '';
}

const modalId = `resource-modal-${id}`;
---

<article class={styles['resource-card']} data-modal-trigger={modalId} style="cursor:pointer;">
  {mediaUrls.length > 0 && (
    <div class={styles['media-preview']}>
      {isYouTubeUrl(mediaUrls[0]) ? (
        <iframe
          src={getYouTubeEmbed(mediaUrls[0])}
          class={styles['media-embed']}
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
          allowfullscreen
          loading="lazy"
          title={title}
        />
      ) : (
        <img
          src={mediaUrls[0]}
          alt={title}
          class={styles['media-img']}
          loading="lazy"
          onerror="this.style.display='none'"
        />
      )}
      {mediaUrls.length > 1 && (
        <span class={styles['media-count']}>+{mediaUrls.length - 1} más</span>
      )}
    </div>
  )}

  <div class={styles['card-header']}>
    <span class={`${styles['type-badge']} ${styles[typeColorMap[type] ?? ''] ?? ''}`}>
      {typeIcons[type] ?? '📌'} {type}
    </span>
    <span class={`${styles['category-label']} ${styles[categoryColorClass[category] ?? ''] ?? ''}`}>{categoryLabels[category] ?? category}</span>
  </div>

  <h3 class={styles['card-title']}>{title}</h3>
  <p class={styles['card-desc']}>{description}</p>

  <div class={styles['tag-list']}>
    {tags.map(tag => (
      <span class={styles['tag']}>{tag}</span>
    ))}
  </div>

  <div class={styles['card-footer']}>
    <span class={styles['added-by']}>
      <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
        <circle cx="12" cy="7" r="4"/>
      </svg>
      {addedBy}
    </span>
    <a href={url} class={styles['visit-btn']} target="_blank" rel="noopener noreferrer" onclick="event.stopPropagation()">
      Visitar
      <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
        <polyline points="15 3 21 3 21 9"/>
        <line x1="10" y1="14" x2="21" y2="3"/>
      </svg>
    </a>
  </div>
</article>

<div class={modal.overlay} id={modalId} data-modal-overlay>
  <div class={modal.modal}>
    <button class={modal.closeBtn} data-modal-close type="button" aria-label="Cerrar">&times;</button>
    <div class={modal.content}>
      <div>
        <div style="display:flex;gap:0.5rem;flex-wrap:wrap;margin-bottom:0.5rem;">
          <span class={`${styles['type-badge']} ${styles[typeColorMap[type] ?? ''] ?? ''}`}>
            {typeIcons[type] ?? '📌'} {type}
          </span>
          <span class={`${styles['category-label']} ${styles[categoryColorClass[category] ?? ''] ?? ''}`}>{categoryLabels[category] ?? category}</span>
        </div>
        <h2 class={modal.title}>{title}</h2>
      </div>

      {mediaUrls.length > 0 && (
        <div class={modal.section}>
          <span class={modal.sectionTitle}>Media</span>
          <div style="display:flex;flex-direction:column;gap:0.5rem;">
            {mediaUrls.map((url) => (
              isYouTubeUrl(url) ? (
                <iframe
                  src={getYouTubeEmbed(url)}
                  style="width:100%;aspect-ratio:16/9;border:none;border-radius:8px;"
                  allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                  allowfullscreen
                  loading="lazy"
                  title={title}
                />
              ) : (
                <img src={url} alt={title} style="width:100%;border-radius:8px;" loading="lazy" />
              )
            ))}
          </div>
        </div>
      )}

      <div class={modal.section}>
        <span class={modal.sectionTitle}>Descripción</span>
        <p class={modal.desc}>{description}</p>
      </div>

      {tags.length > 0 && (
        <div class={modal.section}>
          <span class={modal.sectionTitle}>Tags</span>
          <div class={modal.tags}>
            {tags.map(tag => (
              <span class={modal.tag}>{tag}</span>
            ))}
          </div>
        </div>
      )}

      <div class={modal.section}>
        <span class={modal.sectionTitle}>Agregado por</span>
        <p style="font-size:0.85rem;color:var(--text-secondary);">{addedBy}</p>
      </div>

      <div class={modal.actions}>
        <a href={url} class={`${modal.actionBtn} ${modal.primary}`} target="_blank" rel="noopener noreferrer">
          <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
            <polyline points="15 3 21 3 21 9"/>
            <line x1="10" y1="14" x2="21" y2="3"/>
          </svg>
          Visitar recurso
        </a>
      </div>
    </div>
  </div>
</div>
